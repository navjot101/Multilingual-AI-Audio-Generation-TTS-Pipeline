# LLM Provider (groq | deepseek | openai)
LLM_PROVIDER=groq

# Groq is free — sign up at https://console.groq.com/keys
# GROQ_API_KEY=gsk-your-groq-api-key

# DeepSeek (only needed if LLM_PROVIDER=deepseek)
# DEEPSEEK_API_KEY=sk-your-deepseek-key

# Kafka
KAFKA_BOOTSTRAP=kafka:9092

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Shared audio volume (inside container)
SHARED_AUDIO_PATH=/shared/audio
